{
  "version": 2,
  "installCommand": "cd backend && npm install --legacy-peer-deps",
  "buildCommand": "cd backend && npx prisma generate && cd ../frontend && npm install --include=dev && npx vite build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "backend/prisma/schema.prisma"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
