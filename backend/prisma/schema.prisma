  trigger        String          @default("after") // "before" | "after"
  sequence       Int             @default(10)
  plan           CrmActivityPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  activityType   CrmActivityType @relation(fields: [activityTypeId], references: [id])
  assignedTo     User?           @relation("CrmPlanStepUser", fields: [assignedToId], references: [id])

  @@map("crm_activity_plan_steps")
}

model CrmNote {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  userId    String   @map("user_id")
  content   String
  type      String   @default("note")
  createdAt DateTime @default(now()) @map("created_at")
  lead      CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("crm_notes")
}

model Account {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  nameAr       String        @map("name_ar")
  type         String
  parentId     String?       @map("parent_id")
  balance      Float       @default(0) 
  isActive     Boolean       @default(true) @map("is_active")
  description  String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  journalLines JournalLine[]
  receipts     Receipt[]
  FinancialJournals   FinancialJournal[]
  feeItemsRevenue     FeeItem[]            @relation("FeeItemRevenueAccount")
  feeItemsIncome      FeeItem[]            @relation("FeeItemIncomeAccount")
  feeTemplates        FeeTemplate[]        @relation("FeeTemplateIncomeAccount")
  feeCalculationItems FeeCalculationItem[] @relation("FeeCalculationItemIncomeAccount")

  @@index([type])
  @@index([code])
  @@map("accounts")
}

model JournalEntry {
  id            String            @id @default(uuid())
  entryNumber   String            @unique @map("entry_number")
  date          DateTime          
  description   String
  journalId     String?           @map("journal_id")
  referenceType String?           @map("reference_type")
  referenceId   String?           @map("reference_id")
  isPosted      Boolean           @default(false) @map("is_posted")
  postedBy      String?           @map("posted_by")
  postedAt      DateTime?         @map("posted_at")
  createdBy     String?           @map("created_by")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  reference     String?
  journal       FinancialJournal? @relation(fields: [journalId], references: [id])
  lines         JournalLine[]
  receipts      Receipt[]

  @@index([date])
  @@index([referenceType, referenceId])
  @@map("journal_entries")
}

model FinancialJournal {
  id               String         @id @default(uuid())
  code             String         @unique
  name             String
  nameAr           String         @map("name_ar")
  type             String
  defaultAccountId String?        @map("default_account_id")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  defaultAccount   Account?       @relation(fields: [defaultAccountId], references: [id])
  journalEntries   JournalEntry[]
  payments         Payment[]

  @@map("financial_journals")
}

model JournalLine {
  id          String       @id @default(uuid())
  entryId     String       @map("entry_id")
  accountId   String       @map("account_id")
  debit       Float      @default(0) 
  credit      Float      @default(0) 
  notes       String?
  description String?
  account     Account      @relation(fields: [accountId], references: [id])
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([accountId])
  @@map("journal_lines")
}

model FinancialYear {
  id        String   @id @default(uuid())
  yearName  String   @map("year_name")
  startDate DateTime @map("start_date") 
  endDate   DateTime @map("end_date") 
  isClosed  Boolean  @default(false) @map("is_closed")
  isCurrent Boolean  @default(false) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("financial_years")
}

model Receipt {
  id                 String        @id @default(uuid())
  receiptNumber      String        @unique @map("receipt_number")
  studentId          String        @map("student_id")
  amount             Float       
  amountInWords      String?       @map("amount_in_words")
  paymentMethod      String @map("payment_method")
  referenceNo        String?       @map("reference_no")
  receivedDate       DateTime      @map("received_date") 
  notes              String?
  purpose            String?
  receivedBy         String?       @map("received_by")
  journalEntryId     String?       @map("journal_entry_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  financialAccountId String?       @map("financial_account_id")
  status             String @default("DRAFT")
  financialAccount   Account?      @relation(fields: [financialAccountId], references: [id])
  journalEntry       JournalEntry? @relation(fields: [journalEntryId], references: [id])
  student            Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([receivedDate])
  @@index([status])
  @@map("receipts")
}

model TrialBalance {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  accountCode String   @map("account_code")
  accountName String   @map("account_name")
  debit       Float  
  credit      Float  
  asOfDate    DateTime @map("as_of_date") 
  generatedAt DateTime @default(now()) @map("generated_at")

  @@index([asOfDate])
  @@map("trial_balance_cache")
}

model FinancialSettings {
  id                     String   @id @default(uuid())
  companyNameAr          String   @map("company_name_ar")
  companyNameEn          String   @map("company_name_en")
  trn                    String   @unique
  vatRate                Float  @default(5.00) @map("vat_rate") 
  currency               String   @default("AED")
  bankName               String?  @map("bank_name")
  iban                   String?
  swiftCode              String?  @map("swift_code")
  bankAddress            String?  @map("bank_address")
  defaultCashAccountId   String?  @map("default_cash_account_id")
  defaultBankAccountId   String?  @map("default_bank_account_id")
  defaultVatAccountId    String?  @map("default_vat_account_id")
  defaultIncomeAccountId String?  @map("default_income_account_id")
  defaultSalesDiscountAccountId String? @map("default_sales_discount_account_id")
  defaultPayrollExpenseAccountId String? @map("default_payroll_expense_account_id")
  defaultPayrollPayableAccountId String? @map("default_payroll_payable_account_id")
  defaultSupplierPayableAccountId String? @map("default_supplier_payable_account_id")
  defaultBankSuspenseAccountId String? @map("default_bank_suspense_account_id")
  defaultStudentReceivableAccountId String? @map("default_student_receivable_account_id")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("financial_settings")
}

model Invoice {
  id              String            @id @default(uuid())
  invoiceNumber   String            @unique @map("invoice_number")
  studentId       String?           @map("student_id")
  date            DateTime          @default(now())
  dueDate         DateTime?         @map("due_date")
  subtotal        Float           
  vatAmount       Float           @map("vat_amount") 
  totalAmount     Float           @map("total_amount") 
  status          String     @default("DRAFT")
  trnSnapshot     String?           @map("trn_snapshot")
  vatRateSnapshot Float?          @map("vat_rate_snapshot")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  installments    InstallmentPlan[]
  items           InvoiceItem[]
  paymentId       String?           @unique @map("payment_id")
  payment         Payment?          @relation(fields: [paymentId], references: [id])
  student         Student?          @relation(fields: [studentId], references: [id])

  @@map("invoices")
}

model InvoiceItem {
  id            String  @id @default(uuid())
  invoiceId     String  @map("invoice_id")
  description   String
  quantity      Int     @default(1)
  unitPrice     Float @map("unit_price") 
  taxableAmount Float @map("taxable_amount") 
  vatAmount     Float @map("vat_amount") 
  totalAmount   Float @map("total_amount") 
  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}




















































model BiometricDevice {
  id           String   @id @default(uuid())
  name         String
  ipAddress    String   @map("ip_address")
  port         Int      @default(80)
  username     String   @default("admin")
  password     String
  protocol     String   @default("ISAPI")
  model        String?
  serialNumber String?  @map("serial_number")
  lastSync     DateTime? @map("last_sync")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("biometric_devices")
}
