generator client {
  previewFeatures = ["driverAdapters"]
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  username           String              @unique
  email              String              @unique
  passwordHash       String              @map("password_hash")
  firstName          String?             @map("first_name")
  lastName           String?             @map("last_name")
  phone              String?
  profilePicture     String?             @map("profile_picture")
  isActive           Boolean             @default(true) @map("is_active")
  emailVerified      Boolean             @default(false) @map("email_verified")
  lastLogin          DateTime?           @map("last_login")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  auditLogs          AuditLog[]
  oldCrmActivities   CRMActivity[]       @relation("ActivityUser")
  crmActivities      CrmActivity[]       @relation("CrmUserActivities")
  crmLeads           CrmLead[]           @relation("CrmSalesperson")
  crmNotes           CrmNote[]
  crmTeamsManaged    CrmTeam[]           @relation("CrmTeamLeader")
  employee           Employee?
  assignedLeads      Lead[]              @relation("AssignedLeads")
  lectures           Lecture[]
  parent             Parent?
  performanceReviews PerformanceReview[] @relation("ReviewerUser")
  student            Student?
  userRoles          UserRole[]
  crmTeams           CrmTeam[]           @relation("CrmTeamMembers")
  crmPlanSteps       CrmActivityPlanStep[] @relation("CrmPlanStepUser")

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  isSystemRole    Boolean          @default(false) @map("is_system_role")
  createdAt       DateTime         @default(now()) @map("created_at")
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  resource        String
  action          String
  description     String?
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  roleId    String    @map("role_id")
  scopeType String?   @map("scope_type")
  scopeId   String?   @map("scope_id")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_roles")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  beforeData   String?    @map("before_data")
  afterData    String?    @map("after_data")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ProgramLevel {
  id        String    @id @default(uuid())
  nameAr    String    @map("name_ar")
  nameEn    String    @map("name_en")
  order     Int       @default(0)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  programs  Program[]

  @@map("program_levels")
}

model AwardingBody {
  id          String    @id @default(uuid())
  code        String?   @unique
  nameAr      String    @map("name_ar")
  nameEn      String    @map("name_en")
  description String?
  website     String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  programs    Program[]

  @@map("awarding_bodies")
}

model Program {
  id             String        @id @default(uuid())
  code           String        @unique
  nameAr         String        @map("name_ar")
  nameEn         String        @map("name_en")
  description    String?
  level          String?
  durationMonths Int           @map("duration_months")
  totalUnits     Int?          @map("total_units")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  awardingBodyId String?       @map("awarding_body_id")
  levelId        String?       @map("level_id")
  classes        Class[]
  programUnits   ProgramUnit[]
  awardingBody   AwardingBody? @relation(fields: [awardingBodyId], references: [id])
  programLevel   ProgramLevel? @relation(fields: [levelId], references: [id])

  @@map("programs")
}

model Unit {
  id                  String              @id @default(uuid())
  code                String              @unique
  nameAr              String              @map("name_ar")
  nameEn              String              @map("name_en")
  description         String?
  creditHours         Int?                @map("credit_hours")
  totalLectures       Int                 @map("total_lectures")
  defaultInstructorId String?             @map("default_instructor_id")
  learningOutcomes    String @default("")            @map("learning_outcomes")
  isActive            Boolean             @default(true) @map("is_active")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  assignments         Assignment[]
  classSchedules      ClassUnitSchedule[]
  lectures            Lecture[]
  programUnits        ProgramUnit[]

  @@map("units")
}

model ProgramUnit {
  id            String  @id @default(uuid())
  programId     String  @map("program_id")
  unitId        String  @map("unit_id")
  sequenceOrder Int?    @map("sequence_order")
  isMandatory   Boolean @default(true) @map("is_mandatory")
  program       Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  unit          Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([programId, unitId])
  @@map("program_units")
}

model AcademicYear {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime @map("start_date") 
  endDate   DateTime @map("end_date") 
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  classes   Class[]

  @@map("academic_years")
}

model Class {
  id                 String              @id @default(uuid())
  code               String              @unique
  name               String
  programId          String              @map("program_id")
  startDate          DateTime            @map("start_date") 
  durationMonths     Int                 @map("duration_months")
  expectedEndDate    DateTime?           @map("expected_end_date") 
  actualEndDate      DateTime?           @map("actual_end_date") 
  studyDaysPerWeek   Int?                @map("study_days_per_week")
  studyDays          String @default("")            @map("study_days")
  lectureStartTime   DateTime?           @map("lecture_start_time") 
  lectureEndTime     DateTime?           @map("lecture_end_time") 
  defaultRoom        String?             @map("default_room")
  maxStudents        Int?                @map("max_students")
  status             String              @default("active")
  studyMode          String           @default("IN_PERSON") @map("study_mode")
  studyLanguage      String              @default("Arabic") @map("study_language")
  classroom          String?
  building           String?
  defaultZoomLink    String?             @map("default_zoom_link")
  studyModeChangedAt DateTime?           @map("study_mode_changed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  academicYearId     String?             @map("academic_year_id")
  unitSchedules      ClassUnitSchedule[]
  academicYear       AcademicYear?       @relation(fields: [academicYearId], references: [id])
  program            Program             @relation(fields: [programId], references: [id])
  lectures           Lecture[]
  studentEnrollments StudentEnrollment[]

  @@map("classes")
}

model Lecture {
  id                 String             @id @default(uuid())
  classId            String             @map("class_id")
  unitId             String             @map("unit_id")
  instructorId       String?            @map("instructor_id")
  sequenceNumber     Int                @map("sequence_number")
  scheduledDate      DateTime           @map("scheduled_date") 
  scheduledStartTime DateTime           @map("scheduled_start_time") 
  scheduledEndTime   DateTime           @map("scheduled_end_time") 
  actualStartTime    DateTime?          @map("actual_start_time") 
  actualEndTime      DateTime?          @map("actual_end_time") 
  room               String?
  topic              String?
  status             String             @default("scheduled")
  cancellationReason String?            @map("cancellation_reason")
  notes              String?
  zoomLink           String?            @map("zoom_link")
  zoomMeetingId      String?            @map("zoom_meeting_id")
  zoomPassword       String?            @map("zoom_password")
  actualClassroom    String?            @map("actual_classroom")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  attendanceRecords  AttendanceRecord[]
  class              Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  instructor         User?              @relation(fields: [instructorId], references: [id])
  unit               Unit               @relation(fields: [unitId], references: [id])

  @@index([classId])
  @@index([scheduledDate])
  @@map("lectures")
}

model Student {
  id                        String                  @id @default(uuid())
  userId                    String                  @unique @map("user_id")
  studentNumber             String                  @unique @map("student_number")
  firstNameAr               String?                 @map("first_name_ar")
  lastNameAr                String?                 @map("last_name_ar")
  firstNameEn               String?                 @map("first_name_en")
  lastNameEn                String?                 @map("last_name_en")
  dateOfBirth               DateTime?               @map("date_of_birth") 
  gender                    String?
  nationality               String?
  nationalId                String?                 @map("national_id")
  passportNumber            String?                 @map("passport_number")
  address                   String?
  city                      String?
  country                   String?
  emergencyContactName      String?                 @map("emergency_contact_name")
  emergencyContactPhone     String?                 @map("emergency_contact_phone")
  enrollmentDate            DateTime?               @map("enrollment_date") 
  status                    String                  @default("active")
  createdAt                 DateTime                @default(now()) @map("created_at")
  updatedAt                 DateTime                @updatedAt @map("updated_at")
  platformPassword          String?                 @map("platform_password")
  platformUsername          String?                 @map("platform_username")
  awardType                 String?                 @map("award_type")
  certificateCourseTitle    String?                 @map("certificate_course_title")
  certificateName           String?                 @map("certificate_name")
  email                     String?
  enrolmentNumberAlsalam    String?                 @unique @map("enrolment_number_alsalam")
  fullNameId                String?                 @map("full_name_id")
  fullNamePassport          String?                 @map("full_name_passport")
  notificationCourseTitle   String?                 @map("notification_course_title")
  phone                     String?
  phone2                    String?                 @map("phone2")
  qualificationLevel        String?                 @map("qualification_level")
  registrationDateAlsalam   DateTime?               @map("registration_date_alsalam") 
  registrationNumberPearson String?                 @unique @map("registration_number_pearson")
  specialization            String?
  yearOfAward               String?                 @map("year_of_award")
  passportExpiryDate        DateTime?               @map("passport_expiry_date") 
  attendanceRecords         AttendanceRecord[]
  invoices                  Invoice[]
  receipts                  Receipt[]
  payments                  Payment[]
  studentAssignments        StudentAssignment[]
  enrollments               StudentEnrollment[]
  feeCalculations           StudentFeeCalculation[]
  StudentFee                StudentFee[]
  studentParents            StudentParent[]
  registrations             StudentRegistration[]
  isTaxExempt               Boolean                 @default(false) @map("is_tax_exempt")
  user                      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("students")
}

model Parent {
  id             String          @id @default(uuid())
  userId         String?         @unique @map("user_id")
  relationship   String?
  phone          String?
  email          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  address        String?
  nameAr         String?         @map("name_ar")
  nameEn         String?         @map("name_en")
  nationalId     String?         @map("national_id")
  occupation     String?
  updatedAt      DateTime        @updatedAt @map("updated_at")
  user           User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentParents StudentParent[]

  @@map("parents")
}

model StudentParent {
  studentId String  @map("student_id")
  parentId  String  @map("parent_id")
  isPrimary Boolean @default(false) @map("is_primary")
  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
  @@map("student_parents")
}

model StudentEnrollment {
  id                  String                @id @default(uuid())
  studentId           String                @map("student_id")
  classId             String                @map("class_id")
  enrollmentDate      DateTime              @map("enrollment_date") 
  startUnitId         String?               @map("start_unit_id")
  status              String                @default("active")
  completionDate      DateTime?             @map("completion_date") 
  createdAt           DateTime              @default(now()) @map("created_at")
  attendanceRecords   AttendanceRecord[]
  studentAssignments  StudentAssignment[]
  class               Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  student             Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentUnitProgress StudentUnitProgress[]

  @@unique([studentId, classId])
  @@map("student_enrollments")
}

model StudentUnitProgress {
  id             String            @id @default(uuid())
  studentId      String            @map("student_id")
  enrollmentId   String            @map("enrollment_id")
  unitId         String            @map("unit_id")
  status         String            @default("not_started")
  startDate      DateTime?         @map("start_date") 
  completionDate DateTime?         @map("completion_date") 
  grade          String?
  gpa            Float?          
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  enrollment     StudentEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, enrollmentId, unitId])
  @@map("student_unit_progress")
}

model AttendanceRecord {
  id                  String             @id @default(uuid())
  lectureId           String             @map("lecture_id")
  studentId           String             @map("student_id")
  status              String
  checkInTime         DateTime?          @map("check_in_time")
  checkInMethod       String?            @map("check_in_method")
  notes               String?
  recordedBy          String?            @map("recorded_by")
  createdAt           DateTime           @default(now()) @map("created_at")
  studentEnrollmentId String?            @map("student_enrollment_id")
  lecture             Lecture            @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  studentEnrollment   StudentEnrollment? @relation(fields: [studentEnrollmentId], references: [id])
  student             Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lectureId, studentId])
  @@index([studentId])
  @@index([lectureId])
  @@map("attendance_records")
}

model Assignment {
  id                   String              @id @default(uuid())
  unitId               String              @map("unit_id")
  title                String
  description          String?
  briefFileUrl         String?             @map("brief_file_url")
  rubricFileUrl        String?             @map("rubric_file_url")
  totalMarks           Int?                @map("total_marks")
  passThreshold        Float?            @map("pass_threshold") 
  meritThreshold       Float?            @map("merit_threshold") 
  distinctionThreshold Float?            @map("distinction_threshold") 
  releaseDate          DateTime?           @map("release_date")
  submissionDeadline   DateTime            @map("submission_deadline")
  gracePeriodDays      Int?                @default(0) @map("grace_period_days")
  assessorId           String?             @map("assessor_id")
  internalVerifierId   String?             @map("internal_verifier_id")
  status               String              @default("draft")
  createdBy            String?             @map("created_by")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  attachments          String @default("")
  distinctionCriteria  String?             @map("distinction_criteria")
  instructions         String?
  learningOutcomes     String @default("") @map("learning_outcomes")
  meritCriteria        String?             @map("merit_criteria")
  passCriteria         String?             @map("pass_criteria")
  unit                 Unit                @relation(fields: [unitId], references: [id])
  studentAssignments   StudentAssignment[]

  @@map("assignments")
}

model StudentAssignment {
  id                      String             @id @default(uuid())
  assignmentId            String             @map("assignment_id")
  studentId               String             @map("student_id")
  submissionFileUrl       String?            @map("submission_file_url")
  submissionDate          DateTime?          @map("submission_date")
  isLate                  Boolean            @default(false) @map("is_late")
  plagiarismScore         Float?           @map("plagiarism_score") 
  assessedBy              String?            @map("assessed_by")
  assessedAt              DateTime?          @map("assessed_at")
  marks                   Float?           
  grade                   String?
  assessorFeedback        String?            @map("assessor_feedback")
  assessorFeedbackFileUrl String?            @map("assessor_feedback_file_url")
  verifiedBy              String?            @map("verified_by")
  verifiedAt              DateTime?          @map("verified_at")
  verificationStatus      String?            @map("verification_status")
  verifierNotes           String?            @map("verifier_notes")
  finalStatus             String             @default("pending_submission") @map("final_status")
  gradePublishedAt        DateTime?          @map("grade_published_at")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  attachments             String @default("")
  content                 String?
  remarks                 String?
  studentEnrollmentId     String?            @map("student_enrollment_id")
  submittedAt             DateTime           @default(now()) @map("submitted_at")
  assignment              Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentEnrollment       StudentEnrollment? @relation(fields: [studentEnrollmentId], references: [id])
  student                 Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([finalStatus])
  @@map("student_assignments")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String?
  message   String
  data      String?
  isRead    Boolean   @default(false) @map("is_read")
  sentAt    DateTime? @map("sent_at")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  link      String?

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model ClassUnitSchedule {
  id        String   @id @default(uuid())
  classId   String   @map("class_id")
  unitId    String   @map("unit_id")
  startDate DateTime @map("start_date") 
  endDate   DateTime @map("end_date") 
  status    String   @default("upcoming")
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([classId, unitId])
  @@map("class_unit_schedules")
}

model NotificationPreference {
  userId           String  @map("user_id")
  notificationType String  @map("notification_type")
  emailEnabled     Boolean @default(true) @map("email_enabled")
  smsEnabled       Boolean @default(false) @map("sms_enabled")
  pushEnabled      Boolean @default(true) @map("push_enabled")
  inAppEnabled     Boolean @default(true) @map("in_app_enabled")

  @@id([userId, notificationType])
  @@map("notification_preferences")
}

model SystemSetting {
  key         String   @id
  value       String?
  dataType    String?  @map("data_type")
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Settings {
  id                            String   @id @default("singleton")
  instituteName                 String   @map("institute_name")
  instituteNameAr               String   @map("institute_name_ar")
  instituteNameEn               String   @map("institute_name_en")
  instituteLogo                 String?  @map("institute_logo")
  instituteEmail                String?  @map("institute_email")
  institutePhone                String?  @map("institute_phone")
  instituteAddress              String?  @map("institute_address")
  instituteWebsite              String?  @map("institute_website")
  awardingBodies                String     @default("[]") @map("awarding_bodies")
  defaultAcademicYear           String?  @map("default_academic_year")
  gradePassingPercentage        Int      @default(50) @map("grade_passing_percentage")
  attendanceThreshold           Int      @default(75) @map("attendance_threshold")
  defaultLanguage               String   @default("ar") @map("default_language")
  timezone                      String   @default("Asia/Riyadh")
  dateFormat                    String   @default("DD/MM/YYYY") @map("date_format")
  currency                      String   @default("SAR")
  studentNumberPrefix           String   @default("STU-") @map("student_number_prefix")
  autoGenerateStudentNumber     Boolean  @default(true) @map("auto_generate_student_number")
  emailEnabled                  Boolean  @default(false) @map("email_enabled")
  smtpHost                      String?  @map("smtp_host")
  smtpPort                      Int?     @map("smtp_port")
  smtpUsername                  String?  @map("smtp_username")
  smtpPassword                  String?  @map("smtp_password")
  smsEnabled                    Boolean  @default(false) @map("sms_enabled")
  smsProvider                   String?  @map("sms_provider")
  smsApiKey                     String?  @map("sms_api_key")
  updatedAt                     DateTime @updatedAt @map("updated_at")
  createdAt                     DateTime @default(now()) @map("created_at")
  fullPaymentDiscountAmount     Float  @default(0) @map("full_payment_discount_amount") 
  fullPaymentDiscountPercentage Float  @default(0) @map("full_payment_discount_percentage") 
  lateFeeAmount                 Float  @default(0) @map("late_fee_amount") 
  lateFeeGraceDays              Int      @default(0) @map("late_fee_grace_days")
  taxEnabled                    Boolean  @default(false) @map("tax_enabled")
  taxRate                       Float  @default(15) @map("tax_rate") 
  externalAiApiKey              String?  @map("external_ai_api_key")
  externalAiEnabled             Boolean  @default(false) @map("external_ai_enabled")
  externalAiProvider            String?  @default("openai") @map("external_ai_provider")
  country                       String   @default("SA")
  studentNumberLength           Int      @default(6) @map("student_number_length")
  bankAccountName               String?  @map("bank_account_name")
  bankCurrency                  String?  @default("AED") @map("bank_currency")
  bankIban                      String?  @map("bank_iban")
  bankName                      String?  @map("bank_name")
  bankSwift                     String?  @map("bank_swift")
  trn                           String?  @map("trn")

  // --- HR SETTINGS ---
  hrWorkingDays             String     @default("[\"Sunday\", \"Monday\", \"Tuesday\", \"Wednesday\", \"Thursday\"]") @map("hr_working_days")
  hrWorkStartTime           String   @default("09:00") @map("hr_work_start_time")
  hrWorkEndTime             String   @default("17:00") @map("hr_work_end_time")
  hrLateGracePeriod         Int      @default(15) @map("hr_late_grace_period")
  hrAbsenceThreshold        Int      @default(60) @map("hr_absence_threshold")
  hrLateHourDeduction       Float  @default(0) @map("hr_late_hour_deduction") 
  hrShiftEnabled            Boolean  @default(false) @map("hr_shift_enabled")
  activeTemplate            String   @default("legacy") @map("active_template")
  announcementTicker        String?  @map("announcement_ticker")

  @@map("settings")
}

model StudentRegistration {
  id                 String    @id @default(uuid())
  studentId          String    @map("student_id")
  awardingBodyId     String    @map("awarding_body_id")
  registrationNumber String    @map("registration_number")
  registrationDate   DateTime? @map("registration_date") 
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
